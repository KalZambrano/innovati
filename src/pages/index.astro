---
import Layout from '../layouts/Layout.astro';
import Hero from "../components/Hero.astro";
import LogoBar from "../components/LogoBar.astro";
import About from "../components/About.astro";
import Services from "../components/Services.astro";
import Commitment from "../components/Commitment.astro";
import Process from "../components/Process.astro";
import Contact from "../components/Contact.astro";
import Transition from "../components/Transition.astro";
import Challenges from "../components/Challenges.astro";
---

<Layout>
	<Hero />
	<About />
  <Challenges />
  <Transition />
	<Services />
	<Commitment />
	<LogoBar />
	<Process />
	<Contact />
</Layout>

<script>
  const animatedElements = document.querySelectorAll(".animate-on-enter");

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          const direction = el.dataset.animate ?? "fade-up";
          const delay = el.dataset.delay ? parseInt(el.dataset.delay) : 0;

          setTimeout(() => {
            el.classList.add(`animate-${direction}`, "animate-duration-700", "animate-on-enter");
            el.style.opacity = "1";
          }, delay);

          observer.unobserve(el);
        }
      });
    },
    { threshold: 0.12 }
  );

  animatedElements.forEach((el) => {
    (el as HTMLElement).style.opacity = "0";
    observer.observe(el);
  });
</script>