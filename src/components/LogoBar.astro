---
const partners = [
  { name: "Windows Server logo", logo: "/tech/windows-server.webp" },
  { name: "Azure logo", logo: "/tech/azure.webp" },
  { name: "Microsoft 365 logo", logo: "/tech/microsoft_365.svg" },
  { name: "HP logo", logo: "/tech/hp.webp" },
  { name: "Eset logo", logo: "/tech/eset.webp" },
  { name: "Kaspersky logo", logo: "/tech/kaspersky.png" },
  { name: "Sentinel One logo", logo: "/tech/sentinel-one.webp" },
  { name: "n8n logo", logo: "/tech/n8n-logo.webp" },
  { name: "Lenovo logo", logo: "/tech/lenovo.webp" },
  { name: "HP logo", logo: "/tech/hp.webp" },
];
---

<section class="py-16 lg:py-20 bg-[#f8fafc] border-y border-[#e2e8f0]">
  <div>
    <!-- Header -->
    <div
      class="text-center mb-12 animate-fade-up animate-delay-100 animate-duration-700"
    >
      <span
        class="inline-flex items-center gap-2 text-xs font-bold tracking-[0.2em] uppercase text-(--primary-darker) mb-4"
      >
        <span class="w-8 h-px bg-(--primary-darker)"></span>
        Nuestros Aliados
        <span class="w-8 h-px bg-(--primary-darker)"></span>
      </span>
      <h2 class="text-2xl sm:text-3xl font-bold text-[#0b1928] mb-3">
        Tecnologías con las que <span class="text-(--primary-darker)">trabajamos</span>
      </h2>
      <p class="text-base text-[#64748b] max-w-2xl mx-auto leading-relaxed">
        Seleccionamos herramientas reconocidas por su estabilidad, seguridad y
        capacidad de adaptación para construir soluciones confiables y
        preparadas para evolucionar con tu negocio.
      </p>
    </div>

    <!-- Scrolling logo strip -->
    <div class="relative overflow-hidden py-8">
      <!-- Gradient fade edges — mismo color que el fondo de la sección -->
      <div
        class="absolute inset-y-0 left-0 w-24 bg-linear-to-r from-[#f8fafc] to-transparent z-10"
      >
      </div>
      <div
        class="absolute inset-y-0 right-0 w-24 bg-linear-to-l from-[#f8fafc] to-transparent z-10"
      >
      </div>

      <div class="flex gap-16 animate-scroll-x w-max">
        {
          [...partners, ...partners].map((partner) => (
            <div class="shrink-0 flex items-center justify-center h-16 w-44 opacity-40 hover:opacity-100 transition-all duration-300 hover:scale-110">
              <img
                src={partner.logo}
                alt={partner.name}
                class="h-full w-full object-contain"
              />
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes scroll-x {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }
  .animate-scroll-x {
    animation: scroll-x 28s linear infinite;
  }
  .animate-scroll-x:hover {
    animation-play-state: paused;
  }
</style>
