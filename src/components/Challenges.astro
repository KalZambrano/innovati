---
import { CHALLENGES } from "@/data/site";
---

<article class="py-20 border-t border-(--border) bg-gray-950">
  <div class="container-xl">
    <!-- Header del bloque -->
    <div
      class="text-center max-w-2xl mx-auto mb-14 animate-on-enter"
      data-animate="fade-up"
    >
      <span class="section-eyebrow justify-center">
        <span class="w-6 h-px bg-(--primary)"></span>
        Desafíos comunes
        <span class="w-6 h-px bg-(--primary)"></span>
      </span>
      <h2 class="section-title mb-4">
        ¿Tu empresa enfrenta alguno de
        <span class="text-(--primary)"> estos desafíos?</span>
      </h2>
      <p class="text-(--muted) text-base leading-relaxed">
        Cuando la tecnología deja de acompañar el crecimiento del negocio,
        aparecen interrupciones, retrasos y una mayor carga operativa. Nuestro
        trabajo es ayudarte a recuperar el control.
      </p>
    </div>

    <!-- Grid 3×2 -->
    <div
      class="grid sm:grid-cols-2 lg:grid-cols-3 gap-px bg-(--border) rounded-2xl overflow-hidden border border-(--border)"
    >
      {
        CHALLENGES.map((item, i) => (
          <div
            class="
                bg-(--bg-section)
                p-7
                group
                transition-colors
                duration-300
                animate-on-enter
                relative
                overflow-hidden
              "
            data-animate="fade-up"
          >
            <span class="absolute top-5 right-6 text-5xl font-black text-white/3 select-none leading-none">
              {String(i + 1).padStart(2, "0")}
            </span>

            <div class="flex items-center gap-2 mb-4">
              <span class="w-1.5 h-1.5 rounded-full bg-red-400/70" />
              <h3 class="text-base font-semibold text-white leading-snug group-hover:text-(--primary) transition-colors duration-300 w-2/3">
                {item.title}
              </h3>
            </div>

            <p class="text-sm text-(--muted) leading-relaxed">
              {item.description}
            </p>

            <div class="absolute bottom-0 left-0 h-0.5 w-0 bg-(--primary) transition-all duration-500 group-hover:w-full" />
          </div>
        ))
      }
    </div>
  </div>
</article>
