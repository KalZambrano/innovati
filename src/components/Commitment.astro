---
import { BENEFITS, BEFORE_INNOVA, AFTER_INNOVA } from "@/data/site";
import Check from '@/assets/icons/check-rounded.svg'
import X from '@/assets/icons/cross.svg'
---

<section
  id="compromiso"
  class="py-24 lg:py-32 bg-(--bg-section) relative overflow-hidden"
>
  <!-- Orb decorativo -->
  <div
    class="orb w-125 h-125 bg-(--primary) -bottom-37.5 left-1/2 -translate-x-1/2"
  >
  </div>

  <div class="container-xl relative z-10">
    <!-- Header -->
    <div
      class="text-center max-w-2xl mx-auto mb-16 animate-on-enter"
      data-animate="fade-up"
    >
      <span class="section-eyebrow justify-center">
        <span class="w-6 h-px bg-(--primary)"></span>
        Nuestro Compromiso
        <span class="w-6 h-px bg-(--primary)"></span>
      </span>
      <h2 class="section-title mb-4">
        Beneficios de trabajar con <span class="text-(--primary)">InnovaTI</span
        >
      </h2>
      <p class="text-base text-(--text-body) leading-relaxed">
        Nuestro compromiso es ayudarte a mantener una operación estable,
        organizada y preparada para crecer, centralizando toda la gestión
        tecnológica en un solo equipo.
      </p>
    </div>

    <!-- Comparativa Antes / Después -->
    <div
      class="grid sm:grid-cols-2 gap-4 mb-20 max-w-3xl mx-auto animate-on-enter"
      data-animate="fade-up"
    >
      <!-- Antes -->
      <div class="rounded-2xl border border-red-500/20 bg-red-500/5 p-6">
        <div class="flex items-center gap-2 mb-5">
          <span
            class="text-sm font-semibold tracking-wide text-red-400 uppercase"
          >
            Antes de InnovaTI
          </span>
        </div>
        <ul class="space-y-3">
          {
            BEFORE_INNOVA.map((item) => (
              <li class="flex items-start gap-2.5 text-sm text-(--text-body) leading-relaxed">
                <X class="size-3.5 text-red-400/60 mt-0.5 shrink-0" />
                {item}
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Después -->
      <div
        class="rounded-2xl border border-(--primary)/25 bg-(--primary)/5 p-6"
      >
        <div class="flex items-center gap-2 mb-5">
          <span
            class="text-sm font-semibold tracking-wide text-(--primary) uppercase"
          >
            Después de InnovaTI
          </span>
        </div>
        <ul class="space-y-3">
          {
            AFTER_INNOVA.map((item) => (
              <li class="flex items-start gap-2.5 text-sm text-(--text-body) leading-relaxed">
                <Check class="size-3.5 text-(--primary) mt-0.5 shrink-0" />
                {item}
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <!-- Beneficios principales -->
    <div class="text-center mb-10 animate-on-enter" data-animate="fade-up">
      <span
        class="text-lg font-bold tracking-[0.4em] uppercase text-(--primary)"
      >
        Principales beneficios
      </span>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-16">
      {
        BENEFITS.map((item) => (
          <div
            class="
              card-glass
              relative
              overflow-hidden
              rounded-3xl
              border border-(--border)
              p-7
              text-left
              transition-all
              duration-500
              hover:-translate-y-1
              hover:border-[rgba(3,221,180,.35)]
              hover:shadow-[0_20px_60px_rgba(0,0,0,.25)]
              group
              animate-on-enter
            "
          >
            <div class="absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-[rgba(3,221,180,.45)] to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100" />
            <div class="absolute -right-16 -top-16 h-40 w-40 rounded-full bg-[rgba(3,221,180,.04)] blur-3xl opacity-0 transition-opacity duration-500 group-hover:opacity-100" />

            <item.icon class="size-8 mb-5 text-(--text-body) group-hover:text-(--primary) transition-colors" />

            <h3 class="mb-3 text-lg font-semibold tracking-tight text-white">
              {item.title}
            </h3>
            <p class="text-sm leading-7 text-(--text-body)">
              {item.description}
            </p>

            <div class="absolute bottom-0 left-0 h-0.5 w-0 bg-(--primary) transition-all duration-500 group-hover:w-full" />
          </div>
        ))
      }
    </div>

    <!-- Frase destacada -->
    <div
      class="max-w-2xl mx-auto border-l-4 border-(--primary) pl-6 py-2 animate-on-enter"
      data-animate="fade-up"
    >
      <p
        class="text-lg sm:text-xl font-medium text-white leading-relaxed italic"
      >
        "Gestionar la tecnología no debería ser una preocupación diaria. Nuestro
        trabajo es ayudarte a que funcione de manera ordenada, segura y
        confiable."
      </p>
    </div>
  </div>
</section>
