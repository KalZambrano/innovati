---
import ArrowRight from "@/assets/icons/arrowright.svg";
import { HERO_BENEFITS } from "@/data/site";
---

<section class="min-h-screen bg-[#f0faf8]">
  <div id="inicio" class="relative flex items-center overflow-hidden pt-5">
    <!-- Background orbs -->
    <div class="orb w-150 h-150 bg-(--primary) -top-50 -left-50"></div>
    <div class="orb w-100 h-100 bg-[#0066ff] -bottom-25 -right-25"></div>

    <!-- Grid pattern overlay -->
    <div
      class="absolute inset-0 opacity-[0.04]"
      style="background-image: linear-gradient(var(--primary) 1px, transparent 1px), linear-gradient(90deg, var(--primary) 1px, transparent 1px); background-size: 60px 60px;"
    >
    </div>

    <div class="container-xl relative z-10 py-24 lg:py-32">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <!-- Left content -->
        <div>
          <span class="section-eyebrow animate-fade-in-right animate-delay-200">
            <span class="w-6 h-px bg-(--primary)"></span>
            Outsourcing & Gestión Tecnológica
          </span>

          <h1
            class="text-3xl sm:text-4xl lg:text-5xl xl:text-6xl font-semibold text-[#0b1928] leading-[1.05] mb-6 animate-fade-in-right animate-delay-400"
          >
            Tu departamento de tecnología,
            <span
              class="block text-transparent bg-clip-text bg-linear-to-r from-(--primary) to-(--primary-light)"
            >
              en un solo proveedor
            </span>
          </h1>

          <p
            class="text-lg text-[#475569] mb-8 max-w-lg leading-relaxed animate-fade-in-right animate-delay-600"
          >
            Centralizamos la gestión de TI mediante servicios de soporte,
            infraestructura, nube y ciberseguridad. Ayudamos a mantener una
            operación segura, eficiente y preparada para el crecimiento de tu
            negocio.
          </p>

          <div class="flex flex-col sm:flex-row gap-4">
            <a
              href="#contacto"
              class="btn-primary text-base px-8 py-4 animate-fade-in-right animate-delay-800"
            >
              Solicitar evaluación tecnológica
              <ArrowRight class="size-5" />
            </a>
            <a
              href="#servicios"
              class="btn-outline-dark text-base px-8 py-4 animate-fade-in-left animate-delay-800"
            >
              Conoce nuestros servicios
            </a>
          </div>
        </div>

        <!-- Right — product images mosaic -->
        <div class="relative hidden lg:block">
          <div class="grid grid-cols-2 gap-4 h-145">
            <!-- Col 1: two stacked images -->
            <div class="flex flex-col gap-4">
              <div
                class="flex-1 rounded-2xl overflow-hidden animate-fade-in-down animate-delay-300"
              >
                <img
                  src="/banners/chat-bot.png"
                  alt="Infraestructura TI"
                  fetchpriority="high"
                  class="w-full h-full object-cover"
                />
              </div>
              <div
                class="flex-1 rounded-2xl overflow-hidden animate-fade-in-right animate-delay-300"
              >
                <img
                  src="/banners/soporte-tecnico.png"
                  alt="Seguridad Informática"
                  fetchpriority="high"
                  class="w-full h-full object-cover"
                />
              </div>
            </div>

            <!-- Col 2: two stacked images, offset -->
            <div class="flex flex-col gap-4 mt-8">
              <div
                class="flex-1 rounded-2xl overflow-hidden animate-fade-in-left animate-delay-300"
              >
                <img
                  src="/banners/hardwares.png"
                  alt="Automatización"
                  fetchpriority="high"
                  class="w-full h-full object-cover"
                />
              </div>
              <div
                class="flex-1 rounded-2xl overflow-hidden animate-fade-in-up animate-delay-300"
              >
                <img
                  src="/banners/licencias.png"
                  alt="Cloud y Hosting"
                  fetchpriority="high"
                  class="w-full h-full object-cover"
                />
              </div>
            </div>
          </div>

          <!-- Floating badge -->
          <div
            class="absolute -bottom-4 left-1/2 -translate-x-1/2 bg-white border border-[#e2e8f0] rounded-2xl px-6 py-3 flex items-center gap-3 shadow-xl animate-fade-in-up animate-delay-600"
          >
            <div class="w-4 h-2 rounded-full bg-(--primary) animate-pulse">
            </div>
            <span class="text-sm text-[#0b1928] font-medium">
              Un solo proveedor. Una sola responsabilidad.
            </span>
          </div>
        </div>
      </div>
    </div>
    <div
      class="absolute bottom-0 left-0 right-0 h-16 bg-linear-to-t from-white to-transparent pointer-events-none"
    >
    </div>
  </div>
  <!-- Cards de beneficios — franja blanca debajo del Hero -->
  <div class="bg-white border-b border-[#e2e8f0] pt-10 pb-15 relative">
    <div class="container-xl">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6">
        {
          HERO_BENEFITS.map((item) => (
            <div
              class="flex flex-col items-center text-center gap-3 animate-on-enter"
              data-animate="fade-up"
            >
              <div class="flex items-center justify-center size-14 rounded-2xl bg-(--primary)/10 shrink-0">
                <item.icon class="size-7 text-(--primary)" />
              </div>
              <p class="text-sm font-medium text-[#1e293b] leading-snug">
                {item.label}
              </p>
            </div>
          ))
        }
      </div>
    </div>
    <div
      class="absolute bottom-0 left-0 right-0 h-8 bg-linear-to-b from-white to-[#f0faf8] pointer-events-none"
    >
    </div>
  </div>
</section>
