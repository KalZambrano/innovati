---
import { SERVICES } from "@/data/site";
---

<section id="servicios" class="relative py-24 lg:py-32 px-6">
  <!-- Header opcional -->
  <div class="mb-10 px-6 md:px-10">
    <span class="section-eyebrow">
      <span class="w-6 h-px bg-(--primary)"></span>
      Lo que hacemos
    </span>
    <h2 class="text-3xl font-semibold tracking-tight text-white">
      Nuestros servicios
    </h2>
  </div>

  <!-- Scroll track -->
  <div
    id="services-track"
    class="flex gap-5 overflow-x-auto scroll-smooth
      px-6 py-4 md:px-10
      snap-x snap-mandatory
      cursor-grab active:cursor-grabbing
      select-none"
    style="scrollbar-width: none; -ms-overflow-style: none;"
  >
    {
      SERVICES.map((service) => (
        <article
          class="
            group relative flex shrink-0 flex-col overflow-hidden
            w-[min(340px,80vw)] md:w-92.5
            rounded-3xl border border-(--border)
            bg-white/2 p-7 backdrop-blur-xl
            snap-start
            transition-all duration-500
            hover:-translate-y-1
            hover:border-[rgba(3,221,180,.35)]
          "
        >
          {/* Glow superior */}
          <div class="absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-[rgba(3,221,180,.45)] to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100" />

          {/* Glow radial */}
          <div class="absolute -right-24 -top-24 h-56 w-56 rounded-full bg-[rgba(3,221,180,.05)] blur-3xl opacity-0 transition-all duration-500 group-hover:opacity-100" />

          {/* Icono */}
          <div class="mb-6 flex h-14 w-14 items-center justify-center rounded-2xl border border-(--border) bg-[rgba(3,221,180,.08)] text-white transition-all duration-500 group-hover:border-(--primary) group-hover:bg-[rgba(3,221,180,.15)]">
            <service.icon class="size-7" />
          </div>

          {/* Titulo */}
          <h3 class="mb-3 text-xl font-semibold tracking-tight text-white">
            {service.title}
          </h3>

          {/* Descripcion */}
          <p class="mb-6 line-clamp-3 text-sm leading-7 text-(--text-body)">
            {service.description}
          </p>

          {/* Features */}
          <div class="mb-6 flex flex-wrap gap-2">
            {service.features.map((feature) => (
              <span class="inline-flex items-center gap-1.5 rounded-full border border-(--border) bg-white/3 px-3 py-1.5 text-xs text-(--text-body) transition-colors duration-300 group-hover:border-[rgba(3,221,180,.2)]">
                <span class="size-1 rounded-full bg-(--primary)" />
                {feature}
              </span>
            ))}
          </div>

          {/* Borde inferior animado */}
          <div class="absolute bottom-0 left-0 h-0.5 w-0 bg-(--primary) transition-all duration-500 group-hover:w-full" />
        </article>
      ))
    }

    {/* Spacer final para que la última card no quede pegada al borde */}
    <div class="shrink-0 w-2 md:w-6" aria-hidden="true"></div>
  </div>

  {/* Indicador de scroll */}
  <div
    class="mt-4 flex justify-center gap-1.5 md:hidden"
    id="services-dots"
    aria-hidden="true"
  >
    {
      SERVICES.map((_, i) => (
        <span
          data-dot={i}
          class="h-1 w-1 rounded-full bg-white/20 transition-all duration-300"
        />
      ))
    }
  </div>
</section>

<style>
  #services-track::-webkit-scrollbar {
    display: none;
  }
</style>

<script>
  const track = document.getElementById("services-track") as HTMLElement;
  if (!track) throw new Error("services-track not found");

  // ── Drag to scroll ──────────────────────────────────────────────
  let isDragging = false;
  let startX = 0;
  let scrollStart = 0;

  track.addEventListener("pointerdown", (e) => {
    isDragging = true;
    startX = e.clientX;
    scrollStart = track.scrollLeft;
    track.setPointerCapture(e.pointerId);
  });

  track.addEventListener("pointermove", (e) => {
    if (!isDragging) return;
    const delta = startX - e.clientX;
    track.scrollLeft = scrollStart + delta;
  });

  track.addEventListener("pointerup", () => {
    isDragging = false;
  });
  track.addEventListener("pointercancel", () => {
    isDragging = false;
  });

  // Evitar que el click dispare links/buttons después de drag
  track.addEventListener(
    "click",
    (e) => {
      if (Math.abs(track.scrollLeft - scrollStart) > 4) {
        e.preventDefault();
        e.stopPropagation();
      }
    },
    true,
  );

  // ── Dots indicator (mobile) ──────────────────────────────────────
  const dots = document.querySelectorAll<HTMLElement>("[data-dot]");
  const cards = track.querySelectorAll<HTMLElement>("article");

  if (dots.length) {
    const updateDots = () => {
      const center = track.scrollLeft + track.clientWidth / 2;
      let active = 0;
      cards.forEach((card, i) => {
        const cardCenter = card.offsetLeft + card.offsetWidth / 2;
        if (
          Math.abs(cardCenter - center) <
          Math.abs(
            (cards[active]?.offsetLeft ?? 0) +
              (cards[active]?.offsetWidth ?? 0) / 2 -
              center,
          )
        ) {
          active = i;
        }
      });
      dots.forEach((dot, i) => {
        dot.classList.toggle("bg-[var(--primary)]", i === active);
        dot.classList.toggle("w-4", i === active);
        dot.classList.toggle("bg-white/20", i !== active);
        dot.classList.toggle("w-1", i !== active);
      });
    };

    track.addEventListener("scroll", updateDots, { passive: true });
    updateDots();
  }
</script>
