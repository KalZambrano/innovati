---
import { SERVICES } from "@/data/site";
---

<section
  id="servicios"
  class="relative py-24 lg:py-32 px-6 bg-(--primary-lighter)"
>
  <!-- Header opcional -->
  <div class="mb-10 px-6 md:px-10">
    <span class="section-eyebrow text-[#083344]">
      <span class="w-6 h-px bg-[#083344]"></span>
      Nuestros servicios
    </span>

    <h2 class="text-3xl font-semibold tracking-tight text-(--primary-darker)">
      Soluciones tecnológicas para acompañar el crecimiento de tu empresa
    </h2>

    <p class="mt-2 max-w-3xl text-[#12324a]">
      Ofrecemos un servicio integral para administrar, proteger y optimizar tu
      infraestructura tecnológica, permitiéndote trabajar con un solo proveedor
      y una sola responsabilidad.
    </p>
  </div>

  <!-- Scroll track -->
  <div
    id="services-track"
    class="flex gap-5 overflow-x-auto scroll-smooth
      px-6 py-4 md:px-10
      snap-x snap-mandatory
      cursor-grab active:cursor-grabbing
      select-none"
    style="scrollbar-width: none; -ms-overflow-style: none;"
  >
    {
      SERVICES.map((service) => (
        <article
          class="
            group relative flex shrink-0 flex-col overflow-hidden
            w-[min(340px,80vw)] md:w-92.5
            rounded-3xl
            border border-(--primary-darker)/15
            bg-[#ecfff8]
            p-7
            shadow-[0_12px_35px_rgba(2,154,128,0.08)]
            snap-start
            transition-all duration-500
            hover:-translate-y-1
            hover:border-(--primary)
            hover:bg-white
            hover:shadow-[0_24px_60px_rgba(2,154,128,.15)]
          "
        >
          {/* Glow superior */}
          <div class="absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-(--primary) to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100" />

          {/* Glow radial */}
          <div class="absolute -right-24 -top-24 h-56 w-56 rounded-full bg-(--primary)/10 blur-3xl opacity-0 transition-all duration-500 group-hover:opacity-100" />

          {/* Icono */}
          <div
            class="
              mb-6 flex h-14 w-14 items-center justify-center
              rounded-2xl
              border border-(--primary)/20
              bg-(--primary)/10
              text-(--primary-darker)
              transition-all duration-500
              group-hover:border-(--primary)
              group-hover:bg-(--primary)/20
              group-hover:scale-105
            "
          >
            <service.icon class="size-7" />
          </div>

          {/* Titulo */}
          <h3 class="mb-3 text-xl font-semibold tracking-tight text-[#062c3a]">
            {service.title}
          </h3>

          {/* Descripcion */}
          <p class="mb-6 line-clamp-3 text-sm leading-7 text-[#35616d]">
            {service.description}
          </p>

          {/* Features */}
          <div class="mb-6 flex flex-wrap gap-2">
            {service.features?.map((feature) => (
              <span
                class="
                  inline-flex items-center gap-1.5
                  rounded-full
                  border border-(--primary)/15
                  bg-white/80
                  px-3 py-1.5
                  text-xs
                  text-[#35616d]
                  transition-all duration-300
                  group-hover:border-(--primary)/40
                  group-hover:bg-(--primary)/10
                  group-hover:text-[#062c3a]
                "
              >
                <span class="size-1 rounded-full bg-(--primary)" />
                {feature}
              </span>
            ))}
          </div>

          {/* Borde inferior animado */}
          <div class="absolute bottom-0 left-0 h-0.5 w-0 bg-(--primary) transition-all duration-500 group-hover:w-full" />
        </article>
      ))
    }

    {/* Spacer final para que la última card no quede pegada al borde */}
    <div class="shrink-0 w-2 md:w-6" aria-hidden="true"></div>
  </div>

  {/* Indicador de scroll */}
  <div
    class="mt-4 flex justify-center gap-1.5 md:hidden"
    id="services-dots"
    aria-hidden="true"
  >
    {
      SERVICES.map((_, i) => (
        <span
          data-dot={i}
          class="h-1 w-1 rounded-full bg-[#0b1928]/30 transition-all duration-300"
        />
      ))
    }
  </div>
</section>

<style>
  #services-track::-webkit-scrollbar {
    display: none;
  }
</style>

<script>
  const track = document.getElementById("services-track") as HTMLElement;
  if (!track) throw new Error("services-track not found");

  // ── Drag to scroll ──────────────────────────────────────────────
  let isDragging = false;
  let startX = 0;
  let scrollStart = 0;

  track.addEventListener("pointerdown", (e) => {
    isDragging = true;
    startX = e.clientX;
    scrollStart = track.scrollLeft;
    track.setPointerCapture(e.pointerId);
  });

  track.addEventListener("pointermove", (e) => {
    if (!isDragging) return;
    const delta = startX - e.clientX;
    track.scrollLeft = scrollStart + delta;
  });

  track.addEventListener("pointerup", () => {
    isDragging = false;
  });
  track.addEventListener("pointercancel", () => {
    isDragging = false;
  });

  // Evitar que el click dispare links/buttons después de drag
  track.addEventListener(
    "click",
    (e) => {
      if (Math.abs(track.scrollLeft - scrollStart) > 4) {
        e.preventDefault();
        e.stopPropagation();
      }
    },
    true,
  );

  // ── Dots indicator (mobile) ──────────────────────────────────────
  const dots = document.querySelectorAll<HTMLElement>("[data-dot]");
  const cards = track.querySelectorAll<HTMLElement>("article");

  if (dots.length) {
    const updateDots = () => {
      const center = track.scrollLeft + track.clientWidth / 2;
      let active = 0;
      cards.forEach((card, i) => {
        const cardCenter = card.offsetLeft + card.offsetWidth / 2;
        if (
          Math.abs(cardCenter - center) <
          Math.abs(
            (cards[active]?.offsetLeft ?? 0) +
              (cards[active]?.offsetWidth ?? 0) / 2 -
              center,
          )
        ) {
          active = i;
        }
      });
      dots.forEach((dot, i) => {
        dot.classList.toggle("bg-[#0b1928]", i === active);
        dot.classList.toggle("w-4", i === active);
        dot.classList.toggle("bg-[#0b1928]/30", i !== active);
        dot.classList.toggle("w-1", i !== active);
      });
    };

    track.addEventListener("scroll", updateDots, { passive: true });
    updateDots();
  }
</script>
