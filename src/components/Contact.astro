---
import SendIcon from "@/assets/icons/send.svg";
import WhatsappIcon from "@/assets/social/whatsapp.svg";
import MailIcon from "@/assets/social/mail.svg";
import MapPin from "@/assets/icons/map-pin.svg";
import Check from "@/assets/icons/check-rounded.svg";
import { SITE } from "../data/site";
---

<section
  id="contacto"
  class="py-24 lg:py-32 bg-(--bg-dark) relative overflow-hidden"
>
  <div
    class="orb w-175 h-175 bg-(--primary) top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2"
  >
  </div>

  <div class="max-w-6xl mx-auto px-4 relative z-10">
    <!-- Big CTA card -->
    <div
      class="rounded-3xl border border-(--border) bg-linear-to-br from-(--bg-card) to-(--bg-dark) p-6 sm:p-10 md:p-12 lg:p-16 relative overflow-hidden"
    >
      <div class="grid xl:grid-cols-2 gap-8 lg:gap-12 items-center">
        <!-- Left text -->
        <div>
          <span class="section-eyebrow">
            <span class="w-6 h-px bg-(--primary)"></span>
            ¿Listo para impulsar tu empresa?
          </span>
          <h2
            class="text-2xl sm:text-3xl lg:text-4xl font-bold text-white leading-tight mb-4"
          >
            Hablemos de la tecnología<br />
            <span class="text-(--primary)">que hará crecer tu negocio.</span>
          </h2>

          <p class="text-(--muted) text-base leading-relaxed mb-8 xl:max-w-lg">
            Cuéntanos qué necesita tu empresa y uno de nuestros especialistas se
            pondrá en contacto contigo para analizar tu situación y proponerte
            la solución más adecuada. <span class="text-(--primary-light) font-medium"
              >Sin compromiso.</span
            >
          </p>

          <!-- Contact options -->
          <div class="space-y-6">
            <a
              href={`https://wa.me/51954644519`}
              target="_blank"
              rel="noopener"
              class="flex items-center gap-4 group w-fit"
            >
              <div
                class="w-14 h-14 rounded-xl bg-[rgba(3,221,180,0.1)] border border-(--border) flex items-center justify-center group-hover:bg-[rgba(3,221,180,0.2)] group-hover:border-(--primary) transition-all shrink-0"
              >
                <WhatsappIcon class="size-6 text-(--primary)" />
              </div>
              <div>
                <p class="text-xs font-semibold text-(--primary) uppercase tracking-wider mb-1">WhatsApp</p>
                <p class="text-sm text-(--text-body) mb-0.5">Atención Comercial</p>
                <p
                  class="text-white font-semibold group-hover:text-(--primary) transition-colors"
                >
                  {SITE.phone}
                </p>
              </div>
            </a>

            <a
              href={`mailto:${SITE.email}`}
              class="flex items-center gap-4 group w-fit"
            >
              <div
                class="w-14 h-14 rounded-xl bg-[rgba(3,221,180,0.1)] border border-(--border) flex items-center justify-center group-hover:bg-[rgba(3,221,180,0.2)] group-hover:border-(--primary) transition-all shrink-0"
              >
                <MailIcon class="size-6 text-(--primary)" />
              </div>
              <div>
                <p class="text-xs font-semibold text-(--primary) uppercase tracking-wider mb-1">Correo</p>
                <p class="text-sm text-(--text-body) mb-0.5">Escríbenos</p>
                <p
                  class="text-white font-semibold group-hover:text-(--primary) transition-colors"
                >
                  {SITE.email}
                </p>
              </div>
            </a>

            <div class="flex items-center gap-4 w-fit">
              <div
                class="w-14 h-14 rounded-xl bg-[rgba(3,221,180,0.1)] border border-(--border) flex items-center justify-center shrink-0"
              >
                <MapPin class="size-6 text-(--primary)" />
              </div>
              <div>
                <p class="text-xs font-semibold text-(--primary) uppercase tracking-wider mb-1">Ubicación</p>
                <p class="text-sm text-(--text-body) mb-0.5">Atendemos empresas en todo el Perú</p>
                <p class="text-white font-semibold">Lima - Perú</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Right form -->
        <div class="card-glass rounded-2xl p-5 sm:p-6 md:p-8">
          <h3 class="text-white font-bold text-base sm:text-lg mb-2">
            Solicita una evaluación tecnológica
          </h3>
          <p class="text-(--text-body) text-sm mb-4 sm:mb-6">
            Completa el formulario y te contactaremos para diseñar una propuesta
            a la medida de tu empresa.
          </p>

          <form id="contact-form" class="space-y-3 sm:space-y-4" novalidate>
            <div>
              <label
                for="name"
                class="block text-xs font-semibold text-(--muted) mb-1 sm:mb-1.5"
                >Nombre completo</label
              >
              <input
                type="text"
                id="name"
                name="name"
                required
                placeholder="Juan Pérez"
                class="w-full bg-(--bg-dark) border border-(--border) rounded-lg px-3 sm:px-4 py-2.5 sm:py-3 text-sm text-white placeholder-(--text-body) focus:outline-none focus:border-(--primary) focus:ring-1 focus:ring-(--primary) transition-colors"
              />
            </div>

            <div>
              <label
                for="company"
                class="block text-xs font-semibold text-(--muted) mb-1 sm:mb-1.5"
                >Empresa</label
              >
              <input
                type="text"
                id="company"
                name="company"
                placeholder="Mi Empresa S.A.C."
                class="w-full bg-(--bg-dark) border border-(--border) rounded-lg px-3 sm:px-4 py-2.5 sm:py-3 text-sm text-white placeholder-(--text-body) focus:outline-none focus:border-(--primary) focus:ring-1 focus:ring-(--primary) transition-colors"
              />
            </div>

            <div>
              <label
                for="email"
                class="block text-xs font-semibold text-(--muted) mb-1 sm:mb-1.5"
                >Correo corporativo</label
              >
              <input
                type="email"
                id="email"
                name="email"
                required
                placeholder="nombre@empresa.com"
                class="w-full bg-(--bg-dark) border border-(--border) rounded-lg px-3 sm:px-4 py-2.5 sm:py-3 text-sm text-white placeholder-(--text-body) focus:outline-none focus:border-(--primary) focus:ring-1 focus:ring-(--primary) transition-colors"
              />
            </div>

            <div>
              <label
                for="phone"
                class="block text-xs font-semibold text-(--muted) mb-1 sm:mb-1.5"
                >Teléfono de contacto</label
              >
              <input
                type="tel"
                id="phone"
                name="phone"
                required
                placeholder="+51 987 654 321"
                class="w-full bg-(--bg-dark) border border-(--border) rounded-lg px-3 sm:px-4 py-2.5 sm:py-3 text-sm text-white placeholder-(--text-body) focus:outline-none focus:border-(--primary) focus:ring-1 focus:ring-(--primary) transition-colors"
              />
            </div>

            <div>
              <label
                for="service"
                class="block text-xs font-semibold text-(--muted) mb-1 sm:mb-1.5"
                >Servicio de interés</label
              >
              <select
                id="service"
                name="service"
                class="w-full bg-(--bg-dark) border border-(--border) rounded-lg px-3 sm:px-4 py-2.5 sm:py-3 text-sm text-white focus:outline-none focus:border-(--primary) focus:ring-1 focus:ring-(--primary) transition-colors"
              >
                <option value="">Seleccione una opción</option>
                <option>Outsourcing TI</option>
                <option>Infraestructura Tecnológica</option>
                <option>Seguridad Informática</option>
                <option>Microsoft 365 y Cloud</option>
                <option>Automatización e IA</option>
                <option>Venta de Equipos</option>
                <option>Renting Tecnológico</option>
                <option>Otro</option>
              </select>
            </div>

            <div>
              <label
                for="message"
                class="block text-xs font-semibold text-(--muted) mb-1 sm:mb-1.5"
                >¿Cómo podemos ayudarte?</label
              >
              <textarea
                id="message"
                name="message"
                rows="3"
                placeholder="Cuéntanos brevemente qué necesita tu empresa o el desafío que deseas resolver."
                class="w-full bg-(--bg-dark) border border-(--border) rounded-lg px-3 sm:px-4 py-2.5 sm:py-3 text-sm text-white placeholder-(--text-body) focus:outline-none focus:border-(--primary) focus:ring-1 focus:ring-(--primary) transition-colors resize-none"
              ></textarea>
            </div>

            <button
              type="submit"
              class="btn-primary w-full justify-center py-3 sm:py-3.5 text-sm"
            >
              Enviar consulta
              <SendIcon class="size-4 sm:size-5" />
            </button>
            <span class="text-xs text-(--muted)"
              >Nos pondremos en contacto contigo a la brevedad para conocer las
              necesidades de tu empresa.</span
            >
          </form>

          <!-- Success message (hidden by default) -->
          <div id="form-success" class="hidden text-center py-6 sm:py-8">
            <div
              class="w-14 h-14 sm:w-16 sm:h-16 rounded-full bg-[rgba(3,221,180,0.1)] border border-(--primary) flex items-center justify-center mx-auto mb-3 sm:mb-4"
            >
              <Check class="size-6 sm:size-8 text-(--primary)" />
            </div>
            <h4 class="text-white font-bold text-base sm:text-lg mb-2">
              ¡Mensaje enviado!
            </h4>
            <p class="text-(--muted) text-xs sm:text-sm">
              Nos pondremos en contacto contigo pronto.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement;
  const successMsg = document.getElementById("form-success") as HTMLElement;

  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    // Redirect to WhatsApp with pre-filled message
    const name = (document.getElementById("name") as HTMLInputElement).value;
    const service = (document.getElementById("service") as HTMLSelectElement)
      .value;
    const message = (document.getElementById("message") as HTMLTextAreaElement)
      .value;

    const whatsappText = encodeURIComponent(
      `Hola InnovaTI, soy ${name}. Me interesa el servicio: ${service || "consulta general"}. ${message ? `Mensaje: ${message}` : ""}`,
    );

    form.style.display = "none";
    successMsg.classList.remove("hidden");

    setTimeout(() => {
      window.open(`https://wa.me/51954644519?text=${whatsappText}`, "_blank");
    }, 800);
  });
</script>
